# ---------------------------------------------------------------------------
# Plantilla de variables de entorno. Copiar a `.env` y ajustar.
#   cp .env.example .env
# El archivo `.env` real está ignorado por git (contiene credenciales).
# ---------------------------------------------------------------------------

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=convocatorias
POSTGRES_PASSWORD=cambia_esto_por_una_password_fuerte
POSTGRES_DB=convocatorias

# URL de conexión usada por API y worker.
# Dentro de la red de compose el host de la BD es el servicio `db` (puerto interno 5432).
DATABASE_URL=postgresql+psycopg2://convocatorias:cambia_esto_por_una_password_fuerte@db:5432/convocatorias

# --- Puertos publicados en el host ----------------------------------------
# Ocupados en esta máquina (NO usar): 80, 5050, 5432, 6333, 6334, 6379, 8080, 11434.
DB_PORT=5433
API_PORT=8100
FRONTEND_PORT=8090

# --- Scraping --------------------------------------------------------------
# Intervalo del scheduler (minutos). Default 6h.
SCRAPE_INTERVAL_MINUTES=360
# Keywords del filtro (lista separada por comas, editable sin tocar código).
SCRAPE_KEYWORDS=tecnología,TIC,inclusión digital,población vulnerable,innovación social,educación,transformación digital,software

# --- SECOP II (Socrata) ----------------------------------------------------
# Token opcional; aumenta la cuota de rate limit. Se envía como header X-App-Token.
SECOP_APP_TOKEN=

# --- HTTP ------------------------------------------------------------------
# User-Agent identificable con contacto (buena práctica de scraping responsable).
HTTP_USER_AGENT=ConvocatoriasBot/0.1 (+contacto: sebastian.miranda@arcaoexdi.com)

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO

# --- IA (capa opcional del producto: asistente, resumen y soporte) ---------
# Interruptor maestro. Si es false, los endpoints /ai/* NO tocan la red y
# responden con el fallback controlado (nunca inventan ni rompen la app).
AI_ENABLED=false
# Orden de proveedores a intentar (lista por comas). Ollama local primero,
# OpenRouter como respaldo si Ollama no está disponible.
AI_PROVIDER_ORDER=ollama,openrouter

# --- Ollama (IA local, dentro de la red de compose, sin puerto en el host) -
# Modelo liviano que corre en CPU normal. El servicio `ollama-init` lo descarga
# al levantar el stack (la primera vez pesa varios GB). Puedes cambiarlo por
# otro de https://ollama.com/library (ej. qwen2.5:3b, phi3:mini).
OLLAMA_MODEL=llama3.2:3b
# URL interna de Ollama (no cambiar salvo que muevas el servicio).
OLLAMA_BASE_URL=http://ollama:11434

# --- OpenRouter (respaldo remoto; API compatible con OpenAI) ---------------
# OpenRouter exige crear una cuenta y una API key GRATIS aunque el modelo sea
# ':free' -> https://openrouter.ai/keys . La key vive SOLO en el backend, nunca
# se expone al frontend ni se loguea.
OPENROUTER_API_KEY=
# Debes fijar un modelo ':free' VIGENTE tú mismo: el catálogo gratuito rota.
# Revisa https://openrouter.ai/models?max_price=0 y copia aquí un id vigente
# (ej. algo como "<vendor>/<modelo>:free"). Se deja VACÍO a propósito.
OPENROUTER_MODEL=

# Timeout por request a cada proveedor de IA (segundos). 20s degrada rápido,
# pero un Ollama en CPU con prompts grandes (ej. soporte, que inyecta el manual)
# puede necesitar más. Medido en esta máquina: soporte (inyecta el manual
# completo, ~15KB) tarda ~60-70s con llama3.2:3b en CPU. Con GPU o un modelo
# más pequeño baja mucho. Si ves soporte/resumen cayendo al fallback, sube esto.
AI_REQUEST_TIMEOUT_SECONDS=90
